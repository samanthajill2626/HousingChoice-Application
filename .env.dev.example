# Template for .env.dev — operator-managed secrets for the AWS dev stack.
#   1. Copy this file to .env.dev (gitignored — NEVER commit the real file).
#   2. Fill in the real values.
#   3. Push: npm run secrets:push -- dev
#      Each key lands as SecureString /hc/dev/app/<KEY>; the NEXT deploy
#      hydrates it into /opt/hc/.env on the dev instance.
#   4. Drift check any time: npm run secrets:check -- dev
# Only operator-managed secrets go here. Terraform/deploy-managed keys
# (CF_ORIGIN_SECRET, JOBS_QUEUE_URL, LOG_LEVEL, MEDIA_BUCKET, NODE_ENV, PORT,
# PUBLIC_BASE_URL, SCHEDULER_ROLE_ARN, SCHEDULER_TARGET_ARN, SESSION_SECRET,
# TABLE_PREFIX, DEPLOYED_TAG)
# are refused by the push script. Local-dev settings belong in .env
# (template: .env.example), not here.

# Twilio live credentials. Use the DEV-dedicated API key — dev and prod get
# separate API keys so either can be revoked without touching the other.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=replace-with-twilio-api-key-secret

# Twilio TEST credentials (free sandbox + magic numbers). Dev only — these
# have no counterpart in .env.prod.
TWILIO_TEST_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEST_AUTH_TOKEN=replace-with-twilio-test-auth-token

# Messaging Service the live A2P campaign is bound to (sender pool holds our
# number). All outbound sends go through this service, not a raw From number.
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Voice Intelligence service SID (GAxxxx) for CALL + VOICEMAIL transcription
# (voice-transcription feature). PER-ENV and OPTIONAL: dev and prod each get their
# OWN VI service so completion webhooks never cross environments. Leave unset to keep
# transcription OFF (recordings and voicemails still work; no transcript is requested).
TWILIO_VI_SERVICE_SID=GAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Seconds before the reconcile job re-checks Twilio for a lost transcript webhook
# (default 600). Optional; override only to tune the self-heal delay.
#VOICE_TRANSCRIPT_RECONCILE_SECONDS=600

# OUR business phone numbers, comma-separated E.164 — the numbers in the
# Messaging Service's sender pool. The webhook echo/author check (M1.1) drops
# inbound webhooks whose From matches one of these.
OUR_PHONE_NUMBERS=+15555550100

# Google OAuth client for the dashboard login (M1.3). Create a "Web
# application" OAuth client in the Google Cloud console and register
# https://<dev cloudfront domain>/auth/callback as an authorized redirect
# URI. Use a DEV-dedicated client — dev and prod get separate clients so
# either can be revoked without touching the other.
GOOGLE_CLIENT_ID=replace-with-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Workspace domains allowed to sign in, comma-separated, lowercase (M1.3).
# The callback checks the email domain (authoritative) AND Google's hd claim
# when present (corroboration). Empty would mean NOBODY can log in —
# production refuses to boot without it.
OAUTH_ALLOWED_DOMAINS=housingchoice.org,abt-industries.com

# Web Push VAPID keys (M1.4) for the installable dashboard PWA. Generate ONCE
# with `npm run vapid:keys` and reuse forever — rotating them forces every
# device to re-subscribe. VAPID_PRIVATE_KEY is a secret; the public key is
# sent to browsers (not secret) but lives here too for simplicity.
# VAPID_SUBJECT is a mailto: or https:// URI identifying the sender. ALL THREE
# unset = push is OFF (/api/push/* 503s, pushService no-ops; the app still
# boots — push is a feature, texting/calls are core).
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:ops@housingchoice.org

# A2P outbound throttle (M1.7) — tokens/sec the shared TokenBucket admits before
# the worker dispatches each relay-fan-out / broadcast job (default 1.0 msg/sec,
# deliberately below the registered A2P tier). NOT an operator secret: it is
# TUNING, sourced from Parameter Store the same as the other deploy-managed keys
# in the header above (the secrets:push script refuses it here). Listed for
# visibility only — set the real tier in Parameter Store, not this file.
# A2P_RATE_LIMIT_PER_SEC=1.0

# Per-USER rate limits on the AUTHENTICATED send/call-cost routes (2026-07-02
# hardening) — manual 1:1 send, broadcast send, call originate, cell
# verify-start. Sliding-window per session user; beyond a ceiling → 429
# { error: 'rate_limited' } + Retry-After. Code defaults (30/min, 5/min,
# 10/min, 3 per 180000 ms) apply when unset — leave these commented unless the
# defaults chafe. NOT secrets: tuning, like the A2P throttle above. To tune a
# deployed stack, uncomment + set here, then `npm run secrets:push -- dev`
# (next deploy hydrates it).
# RATE_LIMIT_MANUAL_SEND_PER_MIN=30
# RATE_LIMIT_BROADCAST_SEND_PER_MIN=5
# RATE_LIMIT_ORIGINATE_PER_MIN=10
# RATE_LIMIT_VERIFY_START_MAX=3
# RATE_LIMIT_VERIFY_START_WINDOW_MS=180000

# Inbound voice routing: NO env var. Inbound business calls bridge to the assigned
# inbound-voice-line HOLDER's VERIFIED cell — assigned in Settings > Team (the
# holder must verify their cell first). With no holder configured, an inbound call
# is NOT bridged (it emits an ERROR log → error-logs alarm) and the caller gets
# the "text us" message. (The local dev/e2e stack auto-seeds a placeholder holder
# from a hardcoded fake cell — SEED_INBOUND_VOICE_CELL in seedData.ts — with no env
# var involved; the deployed app never seeds a holder.)

# Relay number-provisioning kill-switch (M1.7 safety). Gates whether creating /
# reopening a relay group may OBTAIN (PURCHASE) a new pool number. DEFAULT when
# unset is OFF on the deployed stacks (twilio driver), so this environment can
# NEVER accidentally buy a real number before A2P approval — relay create/reopen
# returns 503 relay_provisioning_disabled instead, refusing BEFORE the Twilio
# adapter is called. Set RELAY_LIVE_PROVISIONING=true AFTER A2P approval to
# enable real pool-number purchase. It is an APP-BEHAVIOR flag, NOT a secret and
# NOT Terraform-managed — deploy it via secrets:push (push lands it as
# /hc/dev/app/RELAY_LIVE_PROVISIONING for the next deploy to hydrate).
RELAY_LIVE_PROVISIONING=false

# Outbound-SMS kill-switch (A2P safety). Gates whether the app hands ANY text
# message to the real Twilio — 1:1 sends, the missed-call auto-text, welcome
# texts, broadcast, relay fan-out. DEFAULT when unset is OFF on the deployed
# stacks (twilio driver), so this environment sends NO SMS before A2P approval
# (an unregistered-number send draws Twilio 30034 and harms sender reputation);
# sends are refused (503 sms_sending_disabled) BEFORE the Twilio adapter is
# called. VOICE (calls/bridging) is unaffected. Set SMS_SENDING_ENABLED=true
# AFTER A2P approval. APP-BEHAVIOR flag, NOT a secret and NOT Terraform-managed
# — deploy it via secrets:push.
SMS_SENDING_ENABLED=false

# Anthropic API key for conversation fact extraction (Phase 2). The ONLY
# operator SECRET this feature needs; the extraction driver authenticates with
# it. Required only when AI_EXTRACTION_ENABLED=true with EXTRACTION_DRIVER=
# anthropic (loadConfig fails fast on that combo without a key). Never log.
ANTHROPIC_API_KEY=replace-with-anthropic-key

# Conversation fact extraction flags (Phase 2). APP-BEHAVIOR config, NOT secrets
# and NOT Terraform-managed - deploy via secrets:push. AI_EXTRACTION_ENABLED
# gates the whole feature (default OFF when deployed, so it stays dormant until
# the ai_extraction table + ANTHROPIC_API_KEY are in place; flip to true to turn
# it on). EXTRACTION_DRIVER=anthropic is the real driver (console is an offline
# no-op; fake is a test-only seam refused in production). AI_EXTRACTION_MODEL is
# the model id; AI_EXTRACTION_DEBOUNCE_MS is the sliding delay (ms) so a burst of
# texts triggers ONE run.
AI_EXTRACTION_ENABLED=false
EXTRACTION_DRIVER=anthropic
AI_EXTRACTION_MODEL=claude-sonnet-5
AI_EXTRACTION_DEBOUNCE_MS=30000

# OpenTelemetry OTLP export endpoint. When SET, the app/worker export traces and
# metrics over OTLP/HTTP (the SDK appends /v1/traces and /v1/metrics); when unset
# the SDK starts with no exporters (harmless no-op). host.docker.internal is the
# EC2 host — compose maps that name to the host via host-gateway — where the
# CloudWatch agent's OTLP receiver listens on 4318 (traces → X-Ray, metrics →
# CloudWatch CWAgent namespace). Containers can't reach the host as `localhost`,
# hence the host.docker.internal alias. It is an APP-BEHAVIOR config value, NOT a
# secret and NOT Terraform-managed — deploy it via secrets:push (lands as
# /hc/dev/app/OTEL_EXPORTER_OTLP_ENDPOINT for the next deploy to hydrate), the
# same as RELAY_LIVE_PROVISIONING above.
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318

# OTLP export endpoint for METRICS specifically. The CloudWatch agent requires
# each `otlp` receiver section to have its OWN port, so traces and metrics
# cannot share 4318: traces go to the base endpoint above (:4318 — the SDK
# appends /v1/traces), metrics go to the agent's SECOND OTLP port (:4320). These
# two ports MUST match the agent config in infra/modules/ec2/main.tf (4318
# traces / 4320 metrics). Note the per-signal endpoint is used VERBATIM — the
# /v1/metrics path is REQUIRED here (unlike the base endpoint, which gets the
# path appended); a wrong/missing path = silent metric loss. Same deploy
# semantics as the base endpoint: APP-BEHAVIOR config, NOT a secret and NOT
# Terraform-managed — deploy via secrets:push (lands as
# /hc/dev/app/OTEL_EXPORTER_OTLP_METRICS_ENDPOINT). If unset the SDK's metrics
# fall back to the base endpoint (:4318) — which collides with traces on the
# agent — so BOTH must be set together in a real deploy.
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://host.docker.internal:4320/v1/metrics

# Relay number RELEASE gate (D7 retirement). When =true, the retirement sweep
# (npm run pool:retire + the lazy sweep on relay-group provisioning) DELETEs idle
# pool numbers at Twilio after the 180-day grace and drops them from the A2P
# messaging service. DEFAULT when unset: OFF. App-behavior flag, NOT a secret and
# NOT Terraform-managed - deploy via secrets:push. Only an exact =true enables it.
RELAY_NUMBER_RELEASE_ENABLED=true
