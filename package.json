{
  "name": "housingchoice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "app",
    "dashboard"
  ],
  "scripts": {
    "dev": "npm run dev -w app",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "deploy:dev": "node scripts/stub.mjs deploy:dev M0.5",
    "deploy:prod": "node scripts/stub.mjs deploy:prod M0.5",
    "plan": "node scripts/stub.mjs plan M0.4",
    "apply": "node scripts/stub.mjs apply M0.4",
    "drift": "node scripts/stub.mjs drift M0.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.0"
  }
}
