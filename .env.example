# Local development configuration. THIS FILE (.env) IS OPTIONAL — `npm run dev`
# runs fine with NO .env at all (sensible built-in + dev-mode defaults). Copy to
# .env (gitignored) only to OVERRIDE something locally. Precedence (later wins):
# .env.dev (live mode) < .env < real environment variables < dev-mode defaults.
#
# WHAT DOES NOT BELONG HERE (and is therefore not listed below):
#   • Operator secrets — Twilio, Google OAuth, VAPID, OUR_PHONE_NUMBERS,
#     OAUTH_ALLOWED_DOMAINS. In LIVE mode `npm run dev` auto-loads these from the
#     gitignored .env.dev — the SAME values pushed to Parameter Store for
#     deployed dev — so local login/Twilio/push mirror deployed dev. Keep them in
#     .env.dev (template .env.dev.example, `npm run secrets:push`). You CAN set
#     one here to override .env.dev, but you normally never do.
#   • Terraform/deploy-managed keys with no local effect — JOBS_QUEUE_URL,
#     SCHEDULER_TARGET_ARN, SCHEDULER_ROLE_ARN, MEDIA_BUCKET, DASHBOARD_DIST_DIR,
#     and PUBLIC_BASE_URL (which `npm run dev` auto-sets to http://localhost:5173
#     so Google login rides the Vite proxy). Hydrated from Parameter Store in AWS.
#
# Two local modes (scripts/dev.mjs):
#   live (default)   app + worker + dashboard against the REAL dev backend:
#                    hc-dev- DynamoDB tables in us-east-1 via the housingchoice
#                    AWS profile (account-guarded), + .env.dev secrets loaded.
#                    App logs stream to your terminal (CloudWatch is the deployed
#                    server only). Inbound Twilio webhooks still hit the DEPLOYED
#                    dev stack — they can't reach localhost.
#   --local          `npm run dev -- --local` — hermetic loop: DynamoDB Local +
#                    hc-local- tables, no AWS, no .env.dev secrets. Also selected
#                    whenever DYNAMODB_ENDPOINT is set below. The integration test
#                    suite always uses DynamoDB Local.

# Runtime environment: development | production.
NODE_ENV=development

# Which process this instance runs: app (HTTP/API/webhooks) | worker (jobs).
# Only labels OTel traces (off locally); AWS sets it per-container.
HC_PROCESS=app

# HTTP listen port for the app process (CloudFront -> EC2 origin targets 8080).
PORT=8080

# Log verbosity: debug locally; info in AWS.
LOG_LEVEL=debug

# AWS region — everything lives in us-east-1.
AWS_REGION=us-east-1

# Live-mode defaults `npm run dev` already applies — uncomment only to override.
# AWS_PROFILE=housingchoice
# TABLE_PREFIX=hc-dev-

# Hermetic mode — uncommenting DYNAMODB_ENDPOINT forces it (same as --local).
# DynamoDB Local accepts any creds, so no real AWS credentials are needed;
# TABLE_PREFIX then defaults to hc-local-.
# DYNAMODB_ENDPOINT=http://localhost:8000
# TABLE_PREFIX=hc-local-

# Shared secret CloudFront stamps on origin requests; the app rejects requests
# without it (validator middleware, M0.2). This dev placeholder matches the app's
# built-in default, so the local app works whether or not it's set; the real
# value is Terraform-managed in Parameter Store (M0.4). Never log this value.
CF_ORIGIN_SECRET=dev-placeholder-not-a-secret

# Session-cookie secret (M1.3 auth). Like CF_ORIGIN_SECRET it has a built-in dev
# default (this placeholder), so you don't set it locally; the real value is the
# Terraform-generated SecureString /hc/<env>/app/SESSION_SECRET. Production
# refuses to boot with this placeholder. Never log this value.
# SESSION_SECRET=dev-placeholder-session-secret

# OpenTelemetry is disabled locally; OTel exports to CloudWatch (X-Ray traces +
# CWAgent metrics) in AWS only.
OTEL_SDK_DISABLED=true

# OTLP export endpoint for OTel. When SET (and OTEL_SDK_DISABLED unset/false), the
# app/worker export traces and metrics over OTLP/HTTP — the SDK appends /v1/traces
# and /v1/metrics (otel.ts). In AWS this points at the EC2 host's CloudWatch agent
# OTLP receiver (http://host.docker.internal:4318). In a real deploy metrics get
# their OWN port (see OTEL_EXPORTER_OTLP_METRICS_ENDPOINT below) because the agent
# needs one port per otlp receiver section. Leave ALL as-is locally: the dev loop
# keeps OTel disabled (OTEL_SDK_DISABLED=true above), so neither endpoint is active
# (no exporters, no cost).
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://host.docker.internal:4320/v1/metrics

# Outbound messaging driver (M1.1): twilio | console. Defaults to console for
# local NODE_ENVs (sends are logged, redacted, with fake SMconsole-* SIDs) and
# twilio when NODE_ENV=production. Set =twilio for REAL sends from your machine —
# in live mode the TWILIO_* credentials are already loaded from .env.dev.
# MESSAGING_DRIVER=console

# Per-conversation circuit breaker: max AUTOMATED outbound messages per
# conversation per minute before the breaker trips, flips the conversation to
# manual, and ERROR-logs (doc §7.1). Default 10.
# SEND_BREAKER_MAX_PER_MINUTE=10

# Max concurrent GET /api/events SSE streams (M1.2). Each open dashboard tab
# holds one stream (socket + heartbeat + bus listeners) until it closes; beyond
# the cap new streams get 503 with a correlated WARN. Default 50.
# SSE_MAX_CONNECTIONS=50

# Public-surface rate limit (M1.5). Caps requests per window per client IP on
# the UNAUTHENTICATED /public routes (housing-fair intake + flyer) — the abuse
# fence on a surface that spends money (housing-fair sends an SMS). In-memory,
# single-instance (see middleware/rateLimit.ts). Safe defaults so nothing is
# required to boot: 5 requests per 60s per IP. Beyond the cap → 429 with a
# Retry-After header and a correlated WARN (no PII logged).
# PUBLIC_RATE_LIMIT_MAX=5
# PUBLIC_RATE_LIMIT_WINDOW_MS=60000

# Per-USER rate limits on the AUTHENTICATED send/call-cost routes (2026-07-02
# hardening). Sliding-window, keyed by session userId (staff share office IPs),
# in-memory single-instance (see middleware/rateLimit.ts). Each bounds a route
# that spends real money / touches real phones: manual 1:1 send (an SMS each),
# broadcast send (a whole audience fan-out each), call originate (rings two
# real phones), and cell verify-start (SMSes a code to ANY typed number).
# Beyond a ceiling → 429 { error: 'rate_limited' } + Retry-After seconds and a
# correlated WARN (IDs/counts only — no PII logged). Safe defaults so nothing
# is required to boot; the e2e harness raises them (scripts/e2e-session.mjs).
# RATE_LIMIT_MANUAL_SEND_PER_MIN=30
# RATE_LIMIT_BROADCAST_SEND_PER_MIN=5
# RATE_LIMIT_ORIGINATE_PER_MIN=10
# RATE_LIMIT_VERIFY_START_MAX=3
# RATE_LIMIT_VERIFY_START_WINDOW_MS=180000

# A2P outbound throttle (M1.7). Tokens/sec the shared TokenBucket admits before
# the worker dispatches each relay-fan-out / broadcast job, keeping the COMBINED
# outbound rate under the registered A2P tier. DELIBERATELY conservative (1.0
# msg/sec default). A missing/invalid value WARNs and falls back to the default
# — it never crashes boot (texting is core). NOT a secret: lives here / in
# Parameter Store, not the operator-secret .env.<env>.
# A2P_RATE_LIMIT_PER_SEC=1.0

# Relay number-provisioning kill-switch (M1.7 safety). Gates whether creating /
# reopening a relay group may OBTAIN a new pool number. When OFF the relay
# routes refuse with 503 relay_provisioning_disabled BEFORE the messaging
# adapter is called, so a real number is never PURCHASED. DEFAULT when unset:
# ON with the console driver (local/test — fake $0 numbers), OFF with the twilio
# driver (deployed — a fresh provision is a real $ purchase), so no number is
# ever bought accidentally before A2P approval. Set =true (after A2P approval)
# to enable real pool-number purchase. true: true/1/yes; false: false/0/no.
# It is an app-behavior flag, NOT a secret — deployable via secrets:push (NOT
# Terraform-managed). Locally you never set it (the console default is ON).
# RELAY_LIVE_PROVISIONING=true

# Relay number-RELEASE gate (D7 retirement). Gates whether the retirement sweep
# (retireEligible, run lazily on provision + via `npm run pool:retire`) may
# DELETE idle pool numbers at Twilio after their 180-day interception grace.
# DEFAULT when unset: OFF everywhere (deployed AND local) - a release DELETEs a
# real number (and drops it from the A2P messaging service), so it stays off
# until ops turns it on. Only an exact =true enables it. App-behavior flag, NOT
# a secret - deployable via secrets:push (NOT Terraform-managed).
# RELAY_NUMBER_RELEASE_ENABLED=true
