# Dependencies and build output
node_modules/
dist/
coverage/
*.tsbuildinfo

# Environment files — only the committed templates are exempt: .env.example
# (local dev) and .env.<env>.example (deployed secrets for secrets:push)
.env
.env.*
!.env.example
!.env.dev.example
!.env.prod.example

# Terraform — note: .terraform.lock.hcl must be committed, so it is NOT ignored
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
# Generated table definitions (`npm run gen:tables`) MUST be committed — they
# are inputs to plan/apply and plan fails when they are stale.
!*.auto.tfvars.json
crash.log
# Saved plan files from `npm run plan` (consumed by `npm run apply`)
infra/envs/*/tfplan

# Logs
*.log
logs/

# Playwright e2e artifacts
e2e/.artifacts/

# Playwright MCP scratch — screenshots + page-*.yml snapshots. Both MCP servers
# are pinned to this dir via --output-dir (.mcp.json / settings). See CLAUDE.md.
.playwright-mcp/

# OS cruft
.DS_Store
Thumbs.db

# Local-only Claude Code settings
.claude/settings.local.json
~$*.docx

# Brainstorming visual-companion scratch
.superpowers/

# Issue tracker: INDEX.md is a derived, regenerable view (`npm run issues`) — the
# per-issue docs/issues/<slug>.md files are the committed source of truth. Keeping
# the index out of git is what makes concurrent issue-filing conflict-free.
docs/issues/INDEX.md
