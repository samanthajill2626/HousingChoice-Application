# Local development configuration. THIS FILE (.env) IS OPTIONAL — `npm run dev`
# runs fine with no .env at all (sensible built-in + mode defaults). Copy to
# .env (gitignored) only to OVERRIDE something locally. Precedence (later wins):
# .env.dev (live mode) < .env < real environment variables < dev-mode defaults.
#
# You do NOT put operator secrets here. In LIVE mode `npm run dev` automatically
# loads the dev stack's secrets (Twilio, Google OAuth, VAPID, …) from the
# gitignored .env.dev — the SAME values pushed to Parameter Store for deployed
# dev — so local login and tools mirror deployed dev. Keep secrets in .env.dev
# (template .env.dev.example, pushed by `npm run secrets:push`), not here.
#
# Two local modes (scripts/dev.mjs):
#   live (default)   app + worker + dashboard against the REAL dev backend:
#                    hc-dev- DynamoDB tables in us-east-1 via the housingchoice
#                    AWS profile (account-guarded), + .env.dev secrets loaded,
#                    + PUBLIC_BASE_URL auto-set to http://localhost:5173 so
#                    Google login rides the Vite proxy. App logs stream to your
#                    terminal (CloudWatch is the deployed server only). Inbound
#                    Twilio webhooks still hit the DEPLOYED dev stack — they
#                    can't reach localhost.
#   --local          `npm run dev -- --local` — hermetic loop: DynamoDB Local +
#                    hc-local- tables, no AWS, no .env.dev secrets loaded. Also
#                    selected whenever DYNAMODB_ENDPOINT is set below. The
#                    integration test suite always uses DynamoDB Local.
#
# In AWS none of this applies: Parameter Store is the source of truth and the
# deploy path hydrates /opt/hc/.env on the instance.

# Runtime environment: development | production.
NODE_ENV=development

# Which process this instance runs: app (HTTP/API/webhooks) | worker (jobs).
HC_PROCESS=app

# HTTP listen port for the app process (CloudFront -> EC2 origin targets 8080).
PORT=8080

# Log verbosity: debug locally; info in AWS.
LOG_LEVEL=debug

# AWS region — everything lives in us-east-1.
AWS_REGION=us-east-1

# Live mode defaults — uncomment only to override.
# AWS_PROFILE=housingchoice
# TABLE_PREFIX=hc-dev-

# Hermetic mode — uncommenting DYNAMODB_ENDPOINT forces it (same as --local).
# DynamoDB Local accepts any creds, so no real AWS credentials are needed.
# TABLE_PREFIX defaults to hc-local- in this mode.
# DYNAMODB_ENDPOINT=http://localhost:8000
# TABLE_PREFIX=hc-local-

# Shared secret CloudFront stamps on origin requests; the app rejects requests
# without it (validator middleware, M0.2; real value in Parameter Store, M0.4).
# Never log this value.
CF_ORIGIN_SECRET=dev-placeholder-not-a-secret

# OpenTelemetry is disabled locally; OTel exports to CloudWatch Application
# Signals in AWS only.
OTEL_SDK_DISABLED=true

# OTLP export endpoint for OTel -> CloudWatch Application Signals. Seam only
# until the exporter is wired; leave unset locally.
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Job delivery wiring (M1.2) — ALL Terraform-managed in AWS (jobs module ->
# /hc/<env>/app/SCHEDULER_TARGET_ARN / SCHEDULER_ROLE_ARN / JOBS_QUEUE_URL,
# hydrated by the deploy). Leave unset locally: the app uses the in-memory
# scheduler adapter (jobs accepted, never delivered) and the worker starts no
# SQS poll loop. SCHEDULER_TARGET_ARN is the SQS jobs queue ARN one-off
# EventBridge schedules deliver envelopes to; JOBS_QUEUE_URL is the same
# queue's URL, long-polled by the worker.
# SCHEDULER_TARGET_ARN=
# SCHEDULER_ROLE_ARN=
# JOBS_QUEUE_URL=

# Outbound messaging driver (M1.1): twilio | console. Defaults to console for
# local NODE_ENVs (no Twilio account needed — sends are logged, redacted, with
# fake SMconsole-* SIDs) and twilio when NODE_ENV=production (both deployed
# stacks). MESSAGING_DRIVER=twilio requires all TWILIO_* values at startup.
# MESSAGING_DRIVER=console

# Twilio credentials — in LIVE mode these load from .env.dev automatically, so
# you do NOT set them here (uncomment only to override). With the default
# console driver they're unused; flip MESSAGING_DRIVER=twilio for real sends.
# REST auth = API key SID/secret + account SID; the AUTH TOKEN is reserved for
# webhook HMAC validation and is never used for REST. Never log these.
# TWILIO_ACCOUNT_SID=
# TWILIO_API_KEY_SID=
# TWILIO_API_KEY_SECRET=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=

# Public https base URL of the stack (the CloudFront domain) — needed for
# Twilio webhook signature reconstruction + the OAuth callback. Terraform-
# managed in AWS (/hc/<env>/app/PUBLIC_BASE_URL). LOCALLY you don't set this:
# `npm run dev` auto-sets it to http://localhost:5173 so Google login works
# through the Vite proxy. Uncomment only to override.
# PUBLIC_BASE_URL=

# OUR business phone numbers, comma-separated E.164 (M1.1). The Twilio webhook
# echo/author check drops inbound webhooks whose From matches one of these —
# they are our own outbound messages projected back. Operator-managed in AWS
# (.env.dev/.env.prod -> secrets:push). Empty locally (console driver).
# OUR_PHONE_NUMBERS=+15555550100

# S3 bucket inbound MMS media is mirrored into (M1.1). Terraform-managed in
# AWS (/hc/<env>/app/MEDIA_BUCKET from the s3_media module). Leave unset
# locally — media mirroring is skipped with a log line.
# MEDIA_BUCKET=

# Per-conversation circuit breaker: max AUTOMATED outbound messages per
# conversation per minute before the breaker trips, flips the conversation to
# manual, and ERROR-logs (doc §7.1). Default 10.
# SEND_BREAKER_MAX_PER_MINUTE=10

# Max concurrent GET /api/events SSE streams (M1.2). Each open dashboard tab
# holds one stream (socket + heartbeat + bus listeners) until it closes;
# beyond the cap new streams get 503 with a correlated WARN. Default 50.
# SSE_MAX_CONNECTIONS=50

# Session-cookie secret (M1.3 auth). Terraform-managed in AWS
# (/hc/<env>/app/SESSION_SECRET — generated random SecureString, exactly the
# CF_ORIGIN_SECRET pattern). The local default below matches the app's dev
# placeholder; never reuse it deployed. Never log this value.
# SESSION_SECRET=dev-placeholder-session-secret

# Google OAuth client (M1.3) — in LIVE mode `npm run dev` loads these from
# .env.dev automatically, so you do NOT set them here. `npm run dev` also sets
# PUBLIC_BASE_URL=http://localhost:5173 so the callback rides the Vite proxy
# (which stamps the x-origin-verify header a direct :8080 hit lacks). The only
# one-time setup for local login: register http://localhost:5173/auth/callback
# as an authorized redirect URI on the DEV Google OAuth client. Uncomment below
# only to OVERRIDE the .env.dev values locally. Never log these.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Workspace domains allowed to sign in, comma-separated, lowercase (M1.3).
# Empty/unset = NOBODY can log in (safe default; production fails fast
# instead). The callback checks the email domain (authoritative) AND Google's
# hd claim when present (corroboration).
# OAUTH_ALLOWED_DOMAINS=housingchoice.org,abt-industries.com

# Directory of built dashboard assets the app serves statically with SPA
# index.html fallback (M1.3). Set by the Docker image (/srv/app/public).
# Leave unset locally — the Vite dev server (npm run dev -w dashboard, :5173)
# serves the UI and proxies /api + /auth to the app.
# DASHBOARD_DIST_DIR=

# Web Push VAPID keys (M1.4) — OPERATOR-managed secrets (deployed values live
# in .env.dev/.env.prod -> npm run secrets:push). Generate a keypair with
# `npm run vapid:keys` and paste it here to exercise push locally. ALL THREE
# unset = push is OFF: /api/push/* answers 503 push_not_configured and
# pushService no-ops (the app still boots — push is a feature, texting/calls
# are core). VAPID_PRIVATE_KEY is a SECRET; the public key is sent to browsers
# (not secret) but stored the same way for simplicity. VAPID_SUBJECT is a
# mailto: or https:// URI identifying the sender. Never log the private key.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@housingchoice.org
