# Keep the build context lean: the Dockerfile copies manifests + app sources
# explicitly, so everything heavy or irrelevant stays out of the context.
.git
node_modules
**/node_modules
app/dist
app/test
documentation
infra
scripts
dashboard-legacy/*
!dashboard-legacy/package.json
!dashboard-legacy/index.html
!dashboard-legacy/vite.config.ts
!dashboard-legacy/tsconfig.json
!dashboard-legacy/public
!dashboard-legacy/src
*.md
.env
.env.*
.claude
.dockerignore
docker-compose.yml
