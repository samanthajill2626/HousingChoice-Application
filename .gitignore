# Dependencies and build output
node_modules/
dist/
coverage/
*.tsbuildinfo

# Environment files — only the committed templates are exempt: .env.example
# (local dev) and .env.<env>.example (deployed secrets for secrets:push)
.env
.env.*
!.env.example
!.env.dev.example
!.env.prod.example

# Terraform — note: .terraform.lock.hcl must be committed, so it is NOT ignored
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
# Generated table definitions (`npm run gen:tables`) MUST be committed — they
# are inputs to plan/apply and plan fails when they are stale.
!*.auto.tfvars.json
crash.log
# Saved plan files from `npm run plan` (consumed by `npm run apply`)
infra/envs/*/tfplan

# Logs
*.log
logs/

# OS cruft
.DS_Store
Thumbs.db

# Local-only Claude Code settings
.claude/settings.local.json
~$*.docx
