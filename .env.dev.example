# Template for .env.dev — operator-managed secrets for the AWS dev stack.
#   1. Copy this file to .env.dev (gitignored — NEVER commit the real file).
#   2. Fill in the real values.
#   3. Push: npm run secrets:push -- dev
#      Each key lands as SecureString /hc/dev/app/<KEY>; the NEXT deploy
#      hydrates it into /opt/hc/.env on the dev instance.
#   4. Drift check any time: npm run secrets:check -- dev
# Only operator-managed secrets go here. Terraform/deploy-managed keys
# (CF_ORIGIN_SECRET, JOBS_QUEUE_URL, LOG_LEVEL, MEDIA_BUCKET, NODE_ENV, PORT,
# PUBLIC_BASE_URL, SCHEDULER_ROLE_ARN, SCHEDULER_TARGET_ARN, SESSION_SECRET,
# TABLE_PREFIX, DEPLOYED_TAG)
# are refused by the push script. Local-dev settings belong in .env
# (template: .env.example), not here.

# Twilio live credentials. Use the DEV-dedicated API key — dev and prod get
# separate API keys so either can be revoked without touching the other.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=replace-with-twilio-api-key-secret

# Twilio TEST credentials (free sandbox + magic numbers). Dev only — these
# have no counterpart in .env.prod.
TWILIO_TEST_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEST_AUTH_TOKEN=replace-with-twilio-test-auth-token

# Messaging Service the live A2P campaign is bound to (sender pool holds our
# number). All outbound sends go through this service, not a raw From number.
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OUR business phone numbers, comma-separated E.164 — the numbers in the
# Messaging Service's sender pool. The webhook echo/author check (M1.1) drops
# inbound webhooks whose From matches one of these.
OUR_PHONE_NUMBERS=+15555550100

# Google OAuth client for the dashboard login (M1.3). Create a "Web
# application" OAuth client in the Google Cloud console and register
# https://<dev cloudfront domain>/auth/callback as an authorized redirect
# URI. Use a DEV-dedicated client — dev and prod get separate clients so
# either can be revoked without touching the other.
GOOGLE_CLIENT_ID=replace-with-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Workspace domains allowed to sign in, comma-separated, lowercase (M1.3).
# The callback checks the email domain (authoritative) AND Google's hd claim
# when present (corroboration). Empty would mean NOBODY can log in —
# production refuses to boot without it.
OAUTH_ALLOWED_DOMAINS=housingchoice.org,abt-industries.com
