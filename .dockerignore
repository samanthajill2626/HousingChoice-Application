# Keep the build context lean: the Dockerfile copies manifests + app sources
# explicitly, so everything heavy or irrelevant stays out of the context.
.git
node_modules
**/node_modules
app/dist
app/test
documentation
infra
scripts
# Only the files the Dockerfile copies for the shipped dashboard build reach the
# context (dashboard-legacy is no longer shipped — local-only on :5173).
dashboard/*
!dashboard/package.json
!dashboard/index.html
!dashboard/vite.config.ts
!dashboard/tsconfig.json
!dashboard/src
dashboard-legacy
*.md
.env
.env.*
.claude
.dockerignore
docker-compose.yml
