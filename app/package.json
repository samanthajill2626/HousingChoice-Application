{
  "name": "@housingchoice/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "pool:retire": "tsx scripts/retirePoolNumbers.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1068.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1068.0",
    "@aws-sdk/client-dynamodb": "^3.1067.0",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/client-scheduler": "^3.1067.0",
    "@aws-sdk/client-sqs": "^3.1068.0",
    "@aws-sdk/lib-dynamodb": "^3.1067.0",
    "@aws-sdk/lib-storage": "^3.1068.0",
    "@aws-sdk/s3-presigned-post": "^3.1088.0",
    "@aws-sdk/s3-request-presigner": "^3.1083.0",
    "@hyzyla/pdfium": "^2.1.13",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-express": "^0.67.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "express": "^5.2.1",
    "openid-client": "^6.8.4",
    "pino": "^9.14.0",
    "sharp": "^0.35.3",
    "twilio": "^6.0.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "pdf-lib": "^1.17.1",
    "supertest": "^7.2.2"
  }
}
