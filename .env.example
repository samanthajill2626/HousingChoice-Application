# Local development only. In AWS, Parameter Store (SecureString for secrets) is
# the single source of truth; the deploy path hydrates .env on the instance.
# Copy to .env for local use. Never commit .env.

# Runtime environment: development | production.
NODE_ENV=development

# Which process this instance runs: app (HTTP/API/webhooks) | worker (jobs).
HC_PROCESS=app

# HTTP listen port for the app process (CloudFront -> EC2 origin targets 8080).
PORT=8080

# Log verbosity: debug locally; info in AWS.
LOG_LEVEL=debug

# AWS region — everything lives in us-east-1.
AWS_REGION=us-east-1

# DynamoDB Local endpoint for local dev (M0.3: `npm run dev` auto-starts the
# container). Unset in AWS so the SDK targets the real regional endpoint.
# When set, the SDK falls back to dummy credentials — DynamoDB Local accepts
# any creds, so no real AWS credentials are needed for the local loop.
DYNAMODB_ENDPOINT=http://localhost:8000

# Physical DynamoDB table names are `${TABLE_PREFIX}${baseName}` (see
# app/src/lib/tables.ts). hc-local- on dev machines; M0.4 Terraform stacks use
# hc-dev- / hc-prod-. Keys/GSIs are contractual; names come from this prefix.
TABLE_PREFIX=hc-local-

# Shared secret CloudFront stamps on origin requests; the app rejects requests
# without it (validator middleware, M0.2; real value in Parameter Store, M0.4).
# Never log this value.
CF_ORIGIN_SECRET=dev-placeholder-not-a-secret

# OpenTelemetry is disabled locally; OTel exports to CloudWatch Application
# Signals in AWS only.
OTEL_SDK_DISABLED=true

# OTLP export endpoint for OTel -> CloudWatch Application Signals. Seam only
# until the exporter is wired in M0.4/M0.6; leave unset locally.
# OTEL_EXPORTER_OTLP_ENDPOINT=

# EventBridge Scheduler wiring for jobs.enqueue() one-off schedules. Real ARNs
# come from Terraform in M0.4; unset locally (the dev loop uses the in-memory
# scheduler adapter).
# SCHEDULER_TARGET_ARN=
# SCHEDULER_ROLE_ARN=

# ------------------------------------------------------------------------------
# Deployed secrets — .env.dev / .env.prod (NOT part of the local .env above)
#
# The keys below are the operator-managed secrets for the AWS stacks:
#   1. Create .env.dev and .env.prod at the repo root containing ONLY the keys
#      in this section. (The local-dev keys above are Terraform/deploy-managed
#      in AWS — the push script refuses files that contain them.)
#   2. Fill in the real values.
#   3. Push: npm run secrets:push -- dev   (or prod)
#      Each key lands as SecureString /hc/<env>/app/<KEY>; the NEXT deploy
#      hydrates it into /opt/hc/.env on the instance.
#   4. Drift check any time: npm run secrets:check -- dev   (or prod)
# .env.dev and .env.prod are gitignored — NEVER commit the real files.

# Twilio credentials (both .env.dev and .env.prod).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=replace-with-twilio-api-key-secret

# Twilio TEST credentials (.env.dev ONLY — leave these out of .env.prod).
TWILIO_TEST_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEST_AUTH_TOKEN=replace-with-twilio-test-auth-token
