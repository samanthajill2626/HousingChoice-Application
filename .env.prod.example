# Template for .env.prod — operator-managed secrets for the AWS prod stack.
#   1. Copy this file to .env.prod (gitignored — NEVER commit the real file).
#   2. Fill in the real values.
#   3. Push: npm run secrets:push -- prod
#      Each key lands as SecureString /hc/prod/app/<KEY>; the NEXT deploy
#      hydrates it into /opt/hc/.env on the prod instance.
#   4. Drift check any time: npm run secrets:check -- prod
# Only operator-managed secrets go here. Terraform/deploy-managed keys
# (CF_ORIGIN_SECRET, JOBS_QUEUE_URL, LOG_LEVEL, MEDIA_BUCKET, NODE_ENV, PORT,
# PUBLIC_BASE_URL, SCHEDULER_ROLE_ARN, SCHEDULER_TARGET_ARN, SESSION_SECRET,
# TABLE_PREFIX, DEPLOYED_TAG)
# are refused by the push script. NO test credentials in prod — those are
# .env.dev only.

# Twilio live credentials. Use the PROD-dedicated API key — dev and prod get
# separate API keys so either can be revoked without touching the other.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=replace-with-twilio-api-key-secret

# Messaging Service the live A2P campaign is bound to (sender pool holds our
# number). All outbound sends go through this service, not a raw From number.
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OUR business phone numbers, comma-separated E.164 — the numbers in the
# Messaging Service's sender pool. The webhook echo/author check (M1.1) drops
# inbound webhooks whose From matches one of these.
OUR_PHONE_NUMBERS=+15555550100

# Google OAuth client for the dashboard login (M1.3). Create a "Web
# application" OAuth client in the Google Cloud console and register
# https://<prod cloudfront domain>/auth/callback as an authorized redirect
# URI. Use a PROD-dedicated client — dev and prod get separate clients so
# either can be revoked without touching the other.
GOOGLE_CLIENT_ID=replace-with-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Workspace domains allowed to sign in, comma-separated, lowercase (M1.3).
# The callback checks the email domain (authoritative) AND Google's hd claim
# when present (corroboration). Empty would mean NOBODY can log in —
# production refuses to boot without it.
OAUTH_ALLOWED_DOMAINS=housingchoice.org,abt-industries.com

# Web Push VAPID keys (M1.4) for the installable dashboard PWA. Generate ONCE
# with `npm run vapid:keys` and reuse forever — rotating them forces every
# device to re-subscribe. Use a PROD-dedicated keypair (separate from dev).
# VAPID_PRIVATE_KEY is a secret; the public key is sent to browsers (not
# secret) but lives here too for simplicity. VAPID_SUBJECT is a mailto: or
# https:// URI identifying the sender. ALL THREE unset = push is OFF
# (/api/push/* 503s, pushService no-ops; the app still boots — push is a
# feature, texting/calls are core).
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:ops@housingchoice.org

# A2P outbound throttle (M1.7) — tokens/sec the shared TokenBucket admits before
# the worker dispatches each relay-fan-out / broadcast job (default 1.0 msg/sec,
# deliberately below the registered A2P tier). NOT an operator secret: it is
# TUNING, sourced from Parameter Store the same as the other deploy-managed keys
# in the header above (the secrets:push script refuses it here). Listed for
# visibility only — set the real tier in Parameter Store, not this file.
# A2P_RATE_LIMIT_PER_SEC=1.0
